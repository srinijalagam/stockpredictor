# ============================================================================
# Stock Predictor - environment configuration
# Copy this file to ".env" and fill in your keys, then run `make up`.
# ============================================================================

# ---- LLM (OpenAI-compatible) -----------------------------------------------
# Works with OpenAI, Azure OpenAI, or any OpenAI-compatible gateway/local model.
OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
# Optional: override base URL for an OpenAI-compatible endpoint (local LLM, proxy, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1

# ---- Web search ------------------------------------------------------------
# Optional. If set, Tavily is used for higher quality grounded search.
# If empty, the agent falls back to a keyless DuckDuckGo search.
# Either way, results are filtered to the TRUSTED_DOMAINS allowlist below.
TAVILY_API_KEY=

# ---- Trusted sources -------------------------------------------------------
# Comma-separated domain allowlist. Only these sources are used for grounding.
TRUSTED_DOMAINS=reuters.com,bloomberg.com,wsj.com,ft.com,cnbc.com,marketwatch.com,finance.yahoo.com,sec.gov,nasdaq.com,morningstar.com,fool.com,seekingalpha.com,barrons.com,investors.com,forbes.com

# ---- Agent service ---------------------------------------------------------
AGENT_PORT=8000
LOG_LEVEL=info
# Max number of web search results to consider per query
MAX_SEARCH_RESULTS=6
# Request timeout (seconds) for outbound HTTP (company sites, etc.)
HTTP_TIMEOUT=15

# ---- UI service ------------------------------------------------------------
UI_PORT=3000
